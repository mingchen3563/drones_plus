<?xml version="1.0" encoding="UTF-8"?>
<Patch>

	<!--
		Drones Plus — Phase 1
		Tune player bot stations (Logistic mid=2881, Salvage mid=2893, Combat mid=4527):
		  - Set continuous electric draw (energyUsePerSec) to 8 (vanilla: 5).
		  - Set Energy Cell consumption (howMuch) to 0 so stations no longer
		    drain Energy Cells (element 1926) while still triggering the
		    Java charging tick (the dock won't charge a bot if oneChargeNeeds
		    is absent entirely).
	-->

	<!-- Logistic Bot Station: bump electric draw -->
	<Operation Class="AttributeSet">
		<xpath>/data/Element/me[@mid='2881']/data/l/element/features/roboDock</xpath>
		<attribute>energyUsePerSec</attribute>
		<value>8</value>
	</Operation>

	<!-- Logistic Bot Station: zero out Energy Cell consumption -->
	<Operation Class="AttributeSet">
		<xpath>/data/Element/me[@mid='2881']/data/l/element/features/roboDock/oneChargeNeeds/l[@element='1926']</xpath>
		<attribute>howMuch</attribute>
		<value>0</value>
	</Operation>

	<!-- Salvage Bot Station: bump electric draw -->
	<Operation Class="AttributeSet">
		<xpath>/data/Element/me[@mid='2893']/data/l/element/features/roboDock</xpath>
		<attribute>energyUsePerSec</attribute>
		<value>8</value>
	</Operation>

	<!-- Salvage Bot Station: zero out Energy Cell consumption -->
	<Operation Class="AttributeSet">
		<xpath>/data/Element/me[@mid='2893']/data/l/element/features/roboDock/oneChargeNeeds/l[@element='1926']</xpath>
		<attribute>howMuch</attribute>
		<value>0</value>
	</Operation>

	<!-- Combat Bot Station: bump electric draw -->
	<Operation Class="AttributeSet">
		<xpath>/data/Element/me[@mid='4527']/data/l/element/features/roboDock</xpath>
		<attribute>energyUsePerSec</attribute>
		<value>8</value>
	</Operation>

	<!-- Combat Bot Station: zero out Energy Cell consumption -->
	<Operation Class="AttributeSet">
		<xpath>/data/Element/me[@mid='4527']/data/l/element/features/roboDock/oneChargeNeeds/l[@element='1926']</xpath>
		<attribute>howMuch</attribute>
		<value>0</value>
	</Operation>

</Patch>
